# Mako Notification Daemon Configuration
# Theme: Tokyo Night Dark with cyan accents

# Position and anchor
anchor=top-right
# margin=10
# padding=12

# Size constraints
# width=320
# height=110
# max-visible=3

# Visual styling
background-color=#282a36
text-color=#cccce6
border-color=#e680e6
border-size=1
border-radius=6

[urgency=low]
default-timeout=3000

[urgency=normal]
border-color=#f1fa8c
default-timeout=5000

[urgency=high]
border-color=#ff5555
text-color=#e78284
default-timeout=0

# Typography
font=JetBrainsMono Nerd Font 11
markup=1
format=<b>%s</b>\n%b

# Icon settings
icon-path=/usr/share/icons/Tela-dracula
max-icon-size=48

# Behavior
default-timeout=3000
ignore-timeout=0

# Progress bar (for volume, brightness, etc.)
progress-color=over #33467c

# Grouped notifications
group-by=app-name


