#! /usr/bin/zsh


local LOGO_DIR="$HOME/Pictures/pfps"

# TODO: img gets cut off from the bottom when prompt gets rendered

if [ -d "$LOGO_DIR" ] && command -v kitty >/dev/null 2>&1; then
    local RANDOM_LOGO=$(find "$LOGO_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.gif" -o -iname "*.webp" \) | shuf -n 1)
    if [ -n "$RANDOM_LOGO" ]; then
        local SIZE=18
        local cols=$(tput cols)
        local left=$(( (cols - SIZE) / 2 ))
        kitty icat --align center --place "${SIZE}x${SIZE}@${left}x0" "$RANDOM_LOGO"
        printf '\n%.0s' $(seq 1 $((SIZE / 2)))
    fi
fi

