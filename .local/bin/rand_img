#!/usr/bin/zsh
#
LOGO_DIR="${1:-$HOME/Pictures/Pfps}"

RANDOM_LOGO=$(find "$LOGO_DIR" -type f \( \
    -iname "*.jpg"  -o -iname "*.jpeg" -o \
    -iname "*.png"  -o -iname "*.webp" -o \
    -iname "*.gif"  \
\) | shuf -n 1)

[[ -z "$RANDOM_LOGO" ]] && return

kitty icat --clear --align center "$RANDOM_LOGO"
# kitty icat --clear --align center --scale-up --place 20x20@0x0 "$RANDOM_LOGO"
